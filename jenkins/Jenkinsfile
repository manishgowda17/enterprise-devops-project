pipeline {

    agent any

    environment {
        IMAGE_NAME = "enterprise-devops"
        IMAGE_TAG = "${BUILD_NUMBER}"
        COMPOSE_FILE = "docker/docker-compose.yml"
    }

    stages {

        stage('Checkout Source Code') {
            steps {
                echo "📥 Checking out source code..."
                checkout scm
            }
        }

        stage('Project Validation') {
            steps {
                echo "🔍 Running project validation..."
                sh './scripts/validate.sh'
            }
        }

        stage('Verify Docker') {
            steps {
                echo "🐳 Verifying Docker installation..."
                sh 'docker --version'
                sh 'docker compose version'
            }
        }

        stage('Build Docker Image') {
            steps {
                echo "🏗️ Building Docker image..."

                sh """
                docker build \
                -f docker/Dockerfile \
                -t ${IMAGE_NAME}:${IMAGE_TAG} .
                """
            }
        }

        stage('Deploy Application') {
            steps {

                echo "🚀 Deploying application..."

                sh """
                docker compose \
                -f ${COMPOSE_FILE} \
                up -d --build
                """
            }
        }

        stage('AI Deployment Analyzer') {
            steps {

                echo "🤖 Running AI Deployment Analyzer..."

                sh 'python3 scripts/aibuild.py'
            }
        }

        stage('Health Check') {

            steps {

                script {

                    echo "🩺 Checking Application Health..."

                    def status = sh(
                        script: '''
                        sleep 5
                        curl -f http://localhost:5000
                        ''',
                        returnStatus: true
                    )

                    if (status != 0) {

                        echo "❌ Health Check Failed"

                        sh """
                        docker compose \
                        -f ${COMPOSE_FILE} \
                        logs
                        """

                        error("Application failed health check.")

                    }

                    echo "✅ Application is Healthy"

                }

            }

        }

        stage('Pipeline Summary') {

            steps {

                echo """

==========================================
          PIPELINE SUMMARY
==========================================

Build Number : ${BUILD_NUMBER}

Job Name     : ${JOB_NAME}

Docker Image : ${IMAGE_NAME}:${IMAGE_TAG}

Deployment   : SUCCESS

AI Report    : reports/deployment_report.txt

==========================================

"""

            }

        }

    }

    post {

        success {

            echo "🎉 Deployment Successful!"

        }

        failure {

            echo "❌ Deployment Failed!"

        }

        always {

            echo "📦 Archiving AI Deployment Report..."

            archiveArtifacts artifacts: 'reports/deployment_report.txt',
                             fingerprint: true

            echo "🧹 Cleaning Docker Images..."

            sh '''
            docker image prune -f
            docker builder prune -f
            '''

            echo "✅ Pipeline Finished."

        }

    }

}
